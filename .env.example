API_ID=your_api_id_here
API_HASH=your_api_hash_here
GROUP=your_group_numeric_id_here

# Gemini (use one of these; code checks GEMINI_API_KEY first)
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional models (defaults shown)
# GEMINI_WRITER_MODEL=gemini-2.5-flash
# GEMINI_JUDGE_MODEL=gemini-2.5-flash

# Deep Research agent id (see Gemini Deep Research docs)
# GEMINI_DEEP_RESEARCH_AGENT=deep-research-pro-preview-12-2025

# Polling for background Deep Research
# DEEP_RESEARCH_POLL_SECONDS=10
# DEEP_RESEARCH_MAX_WAIT_SECONDS=1800
