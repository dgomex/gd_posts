# =====================================================================
# gd_posts environment configuration
#
# Pydantic-settings reads these via the "WRITER__*" / "JUDGE__*" nested
# convention (env_nested_delimiter="__"). You can configure the writer
# and judge LLMs completely independently — different providers, hosts,
# models, and temperatures are all fine.
# =====================================================================

# --- Writer LLM ---------------------------------------------------------
WRITER__PROVIDER=google_genai
WRITER__MODEL=gemini-2.0-flash
WRITER__API_KEY=
# WRITER__BASE_URL=
WRITER__TEMPERATURE=0.8

# --- Judge LLM ----------------------------------------------------------
JUDGE__PROVIDER=google_genai
JUDGE__MODEL=gemini-2.0-flash
JUDGE__API_KEY=
# JUDGE__BASE_URL=
JUDGE__TEMPERATURE=0.2

# --- Loop control -------------------------------------------------------
MAX_ITERATIONS=3

# =====================================================================
# Provider switching examples — uncomment to use
# =====================================================================

# OpenAI:
# WRITER__PROVIDER=openai
# WRITER__MODEL=gpt-4o-mini
# WRITER__API_KEY=sk-...

# OpenAI-compatible API (e.g. vLLM, LM Studio, Together AI):
# WRITER__PROVIDER=openai
# WRITER__MODEL=meta-llama/Llama-3.1-70B-Instruct
# WRITER__BASE_URL=https://api.together.xyz/v1
# WRITER__API_KEY=your-together-key

# Ollama Cloud — https://ollama.com
# WRITER__PROVIDER=ollama_cloud
# WRITER__MODEL=gpt-oss:120b-cloud
# WRITER__API_KEY=your-ollama-cloud-key

# Local Ollama:
# WRITER__PROVIDER=ollama
# WRITER__MODEL=llama3.1
# WRITER__BASE_URL=http://localhost:11434
