# --- Telegram (Telethon) ---
# From https://my.telegram.org/apps — API_ID must be digits only.
API_ID=
API_HASH=
# Numeric chat ID (e.g. supergroup often looks like -100…).
GROUP=

# --- Gemini Deep Research (google-genai) ---
# Either GEMINI_API_KEY or GOOGLE_API_KEY is read by the client.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional: override the Deep Research agent id (see Gemini Deep Research API docs).
# GEMINI_DEEP_RESEARCH_AGENT=deep-research-pro-preview-12-2025

# --- LiteLLM blog writer / judge (see https://docs.litellm.ai/docs/) ---
# Base URL for the completion API (default in code: https://ollama.com).
# LLM_BASE_URL=https://ollama.com
# If your provider needs a key, set the env var that LiteLLM expects for that provider
# (e.g. OPENAI_API_KEY, ANTHROPIC_API_KEY).
# Ollama Cloud (e.g. gemma3:4b-cloud): https://ollama.com — often OLLAMA_API_KEY.
# OLLAMA_API_KEY=
